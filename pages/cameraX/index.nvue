<template>
  <view class="page">
    <xyc-markvideo
      ref="nativeCamera"
      class="nativePreview"
      :style="cameraViewportStyle"
      :mode="mode"
      :target-fps="targetFps"
      :camera-sound-enabled="cameraSoundEnabled"
      :status-text="nativeStatus"
      @nativeviewready="handleNativeReady"
      @cameraready="handleCameraReady"
      @nativeerror="handleNativeError"
      @photodone="handlePhotoDone"
      @recordstart="handleRecordStart"
      @recorddone="handleRecordDone"
      @flashchange="handleFlashChange"
      @zoomchange="handleZoomChange"
      @camerachange="handleCameraChange"
    />

    <movable-area class="watermarkLayer" :style="watermarkLayerStyle" v-if="activeWatermark">
      <movable-view
        class="watermarkGesturePlane"
        :x="watermarkMoveX"
        :y="watermarkMoveY"
        direction="all"
        :animation="false"
        :disabled="watermarkMoveDisabled"
        :style="watermarkBoxStyle"
        @touchstart="startWatermarkTouch"
        @touchmove="moveWatermarkTouch"
        @change="handleWatermarkMoveChange"
        @touchend="finishWatermarkTouch"
        @touchcancel="finishWatermarkTouch"
      >
        <view
          v-if="!watermarkPinchActive()"
          class="watermarkTransformBox"
          :key="watermarkRenderKey"
          :style="watermarkTransformStyle"
        >
          <view
            class="watermarkContent"
            :style="watermarkContentStyle"
          >
            <image
              v-if="watermarkHasImage"
              class="watermarkImage"
              :style="watermarkImageStyle"
              :src="activeWatermark.imagePath"
            ></image>
            <view v-if="watermarkHasText" class="watermarkTextBlock">
              <text class="watermarkMainText" :style="watermarkMainTextStyle">{{ activeWatermark.mainTitleText }}</text>
              <text v-if="activeWatermark.subtitleText" class="watermarkSubText" :style="watermarkSubTextStyle">{{ activeWatermark.subtitleText }}</text>
            </view>
          </view>
          <view
            class="watermarkDelete"
            :style="watermarkDeleteStyle"
            @click.stop="clearActiveWatermark"
            @touchstart.stop="stopWatermarkTouch"
            @touchmove.stop="stopWatermarkTouch"
            @touchend.stop="stopWatermarkTouch"
            @touchcancel.stop="stopWatermarkTouch"
          >
            <text class="watermarkDeleteText" :style="watermarkControlTextStyle">×</text>
          </view>
          <view
            class="watermarkRotate"
            :style="watermarkRotateStyle"
            @click.stop="rotateWatermarkQuarterTurn"
            @touchstart.stop="stopWatermarkTouch"
            @touchmove.stop="stopWatermarkTouch"
            @touchend.stop="stopWatermarkTouch"
            @touchcancel.stop="stopWatermarkTouch"
          >
            <text class="watermarkRotateText" :style="watermarkControlTextStyle">↻</text>
          </view>
          <view
            class="watermarkResize"
            :style="watermarkResizeStyle"
          >
            <view class="watermarkResizeGlyph" :style="watermarkControlTextStyle">
              <view class="watermarkResizeTopHorizontal"></view>
              <view class="watermarkResizeTopVertical"></view>
              <view class="watermarkResizeTopDiagonal"></view>
              <view class="watermarkResizeBottomHorizontal"></view>
              <view class="watermarkResizeBottomVertical"></view>
              <view class="watermarkResizeBottomDiagonal"></view>
            </view>
          </view>
        </view>
      </movable-view>
    </movable-area>
    <view class="watermarkPinchVisualLayer" :style="watermarkLayerStyle" v-if="activeWatermark && watermarkPinchActive()">
      <view class="watermarkTransformBox" :key="watermarkRenderKey" :style="watermarkTransformStyle">
        <view
          class="watermarkContent"
          :style="watermarkContentStyle"
        >
          <image
            v-if="watermarkHasImage"
            class="watermarkImage"
            :style="watermarkImageStyle"
            :src="activeWatermark.imagePath"
          ></image>
          <view v-if="watermarkHasText" class="watermarkTextBlock">
            <text class="watermarkMainText" :style="watermarkMainTextStyle">{{ activeWatermark.mainTitleText }}</text>
            <text v-if="activeWatermark.subtitleText" class="watermarkSubText" :style="watermarkSubTextStyle">{{ activeWatermark.subtitleText }}</text>
          </view>
        </view>
        <view
          class="watermarkDelete"
          :style="watermarkDeleteStyle"
          @click.stop="clearActiveWatermark"
          @touchstart.stop="stopWatermarkTouch"
          @touchmove.stop="stopWatermarkTouch"
          @touchend.stop="stopWatermarkTouch"
          @touchcancel.stop="stopWatermarkTouch"
        >
          <text class="watermarkDeleteText" :style="watermarkControlTextStyle">×</text>
        </view>
        <view
          class="watermarkRotate"
          :style="watermarkRotateStyle"
          @click.stop="rotateWatermarkQuarterTurn"
          @touchstart.stop="stopWatermarkTouch"
          @touchmove.stop="stopWatermarkTouch"
          @touchend.stop="stopWatermarkTouch"
          @touchcancel.stop="stopWatermarkTouch"
        >
          <text class="watermarkRotateText" :style="watermarkControlTextStyle">↻</text>
        </view>
        <view
          class="watermarkResize"
          :style="watermarkResizeStyle"
        >
          <view class="watermarkResizeGlyph" :style="watermarkControlTextStyle">
            <view class="watermarkResizeTopHorizontal"></view>
            <view class="watermarkResizeTopVertical"></view>
            <view class="watermarkResizeTopDiagonal"></view>
            <view class="watermarkResizeBottomHorizontal"></view>
            <view class="watermarkResizeBottomVertical"></view>
            <view class="watermarkResizeBottomDiagonal"></view>
          </view>
        </view>
      </view>
    </view>

    <cover-view class="topBar">
      <cover-view class="topSide">
        <cover-view class="backButton" @click="goBack">
          <text class="backIcon">‹</text>
        </cover-view>
      </cover-view>
      <cover-view class="topTitleBox">
        <text class="topTitle">{{ mode === 'video' ? '视频' : '照片' }}</text>
        <text class="topSub">{{ nativeStatus }}</text>
      </cover-view>
      <cover-view class="topRightSide">
        <cover-view class="flashTapArea" @click="cycleFlashMode">
          <cover-view :class="flashPillClass" @click="cycleFlashMode">
            <text :class="flashIconClass" @click="cycleFlashMode">⚡︎</text>
            <text :class="flashTextClass" @click="cycleFlashMode">{{ flashModeText }}</text>
          </cover-view>
        </cover-view>
        <cover-view class="switchCameraTapArea" @click.stop="switchCameraFacing">
          <cover-view :class="switchCameraButtonClass">
            <text class="switchCameraIcon">⇄</text>
          </cover-view>
        </cover-view>
      </cover-view>
    </cover-view>

    <cover-view class="recordHud" v-if="isRecording">
      <cover-view class="recordBubble">
        <cover-view :class="recordDotClass"></cover-view>
        <text class="recordHudText">{{ recordElapsedText }}</text>
      </cover-view>
    </cover-view>

    <cover-view class="zoomRail">
      <cover-view :class="wideZoomButtonClass" @click="setZoomMode('wide')">
        <text :class="wideZoomTextClass">广角</text>
      </cover-view>
      <cover-view :class="normalZoomButtonClass" @click="setZoomMode('1x')">
        <text :class="normalZoomTextClass">1x</text>
      </cover-view>
      <cover-view :class="teleZoomButtonClass" @click="setZoomMode('2x')">
        <text :class="teleZoomTextClass">2x</text>
      </cover-view>
    </cover-view>

    <cover-view class="bottomPanel">
      <cover-view class="modeSwitchWrap">
        <cover-view class="cameraSoundTapArea" @click="toggleCameraSound">
          <cover-view :class="cameraSoundPillClass">
            <cover-view class="cameraSoundIcon">
              <text :class="cameraSoundIconTextClass">♪</text>
            </cover-view>
            <text :class="cameraSoundTextClass">{{ cameraSoundModeText }}</text>
          </cover-view>
        </cover-view>
        <cover-view class="modeSwitch">
          <cover-view :class="videoModeButtonClass" @click="setMode('video')">
            <text :class="videoModeTextClass">视频</text>
          </cover-view>
          <cover-view :class="photoModeButtonClass" @click="setMode('photo')">
            <text :class="photoModeTextClass">照片</text>
          </cover-view>
        </cover-view>
      </cover-view>

      <cover-view class="mainControls">
        <cover-view class="shutterWrap">
          <cover-view :class="shutterClass" @click="pressShutter">
            <cover-view :class="shutterCoreClass"></cover-view>
          </cover-view>
        </cover-view>
        <cover-view class="resultButton controlLeft" @click="openSystemAlbum">
          <cover-view :class="lastMediaThumbClass">
            <cover-image v-if="lastMediaThumbSource" class="resultThumbImage" :src="lastMediaThumbSource"></cover-image>
            <text v-if="!lastMediaThumbSource" class="resultThumbIcon">相</text>
            <text v-if="lastMediaResult && lastMediaResult.kind === 'video'" class="resultVideoBadge">▶</text>
          </cover-view>
        </cover-view>
        <cover-view class="cameraButton controlRight" @click="openWatermarkSheet">
          <text class="cameraIcon">印</text>
        </cover-view>
      </cover-view>
    </cover-view>

    <cover-view v-if="showWatermarkSheet" class="watermarkSheetMask" @click="closeWatermarkSheet">
      <cover-view class="watermarkSheet" @click.stop>
        <cover-view class="watermarkSheetHeader">
          <text class="watermarkSheetTitle">水印模板</text>
          <text class="watermarkSheetClose" @click="closeWatermarkSheet">×</text>
        </cover-view>
        <cover-view class="watermarkEmpty" v-if="!activeWatermark">
          <text class="watermarkEmptyText">选择模板后，可拖拽、缩放，点左上角旋转。</text>
        </cover-view>
        <cover-view
          v-for="template in watermarkTemplates"
          :key="template.templateId"
          :class="watermarkTemplateCardClass(template)"
          @click="selectWatermarkTemplate(template)"
        >
          <cover-view class="watermarkPreview" :style="{ backgroundColor: template.boxBackgroundColor }">
            <cover-image v-if="template.imagePath" class="watermarkPreviewImage" :src="template.imagePath"></cover-image>
            <cover-view v-if="template.templateType !== 'image'" class="watermarkPreviewText">
              <text class="watermarkPreviewTitle">{{ template.mainTitleText }}</text>
              <text v-if="template.subtitleText" class="watermarkPreviewSub">{{ template.subtitleText }}</text>
            </cover-view>
          </cover-view>
          <cover-view class="watermarkTemplateMeta">
            <text class="watermarkTemplateName">{{ template.templateName }}</text>
            <text class="watermarkTemplateType">{{ templateTypeLabel(template.templateType) }}</text>
          </cover-view>
        </cover-view>
      </cover-view>
    </cover-view>
  </view>
</template>

<script>
const WATERMARK_STORAGE_KEY = 'xyc-camera-watermark-template'
const WATERMARK_HANDLE_PAD = 30
const WATERMARK_HANDLE_SIZE = 42
const WATERMARK_HANDLE_INSET = 9
const WATERMARK_DEFAULT_MIN_WIDTH = 92
const WATERMARK_DEFAULT_MIN_HEIGHT = 64
const WATERMARK_MIN_SCALE = 0.55
const WATERMARK_ABSOLUTE_MIN_SCALE = 0.28
const WATERMARK_MAX_SCALE = 2.2
const WATERMARK_PINCH_MIN_DISTANCE = 8
const WATERMARK_PINCH_FRAME_INTERVAL_MS = 16
const WATERMARK_PINCH_MAX_SCALE_STEP = 0.12
const WATERMARK_PINCH_SMOOTHING = 0.45
const WATERMARK_TRACE_LOG = false
let watermarkTraceAndroidLog = null
const RECORD_STOP_TIMEOUT_MS = 12000
const PORTRAIT_LAYOUT_FALLBACK_WIDTH = 375
const PORTRAIT_LAYOUT_FALLBACK_HEIGHT = 812
const CAMERA_TOP_BAR_HEIGHT = 90
const CAMERA_BOTTOM_PANEL_HEIGHT = 176
const CAMERA_VIEWPORT_ASPECT_WIDTH = 3
const CAMERA_VIEWPORT_ASPECT_HEIGHT = 4
const RESULT_CACHE_LIMIT = 4

export default {
  data() {
    const screen = resolveScreenBounds()
    const viewport = resolveCameraViewportBounds(screen.width, screen.height)
    return {
      mode: 'photo',
      targetFps: 30,
      flashMode: 'off',
      flashTapAt: 0,
      flashPending: false,
      flashRequestSilent: false,
      flashEventHandled: false,
      flashEventApplied: true,
      cameraFacing: 'back',
      cameraSwitchPending: false,
      cameraSwitchTapAt: 0,
      zoomMode: '1x',
      zoomPending: false,
      zoomRequestSilent: false,
      zoomEventHandled: false,
      zoomEventApplied: true,
      nativeStatus: '相机初始化中',
      nativeReady: false,
      lastNativeError: null,
      isRecording: false,
      stopPending: false,
      recordStartPending: false,
      recordStartPendingTimer: null,
      recordStopPendingTimer: null,
      recordStartedAt: 0,
      recordElapsedMs: 0,
      recordBlinkOn: true,
      cameraSoundEnabled: true,
      cameraSoundPending: false,
      recordTimer: null,
      recordPermissionRetryTimer: null,
      recordStartRetryTimer: null,
      recordPermissionRetryCount: 0,
      recordStartAfterPermission: false,
      lastMediaResult: null,
      recentMediaResults: [],
      showWatermarkSheet: false,
      watermarkTemplates: createWatermarkTemplates(),
      activeWatermark: null,
      watermarkRenderKey: 0,
      watermarkTransitionDisabled: false,
      watermarkTransitionTimer: null,
      watermarkFrame: {
        left: viewport.left + viewport.width * 0.14,
        top: viewport.top + viewport.height * 0.18,
        width: viewport.width * 0.62,
        height: 82,
        scale: 1,
        rotation: 0
      },
      watermarkPinchGesture: null,
      watermarkMoveActive: false,
      watermarkMoveDraft: null,
      watermarkSyncTimer: null,
      watermarkSyncVersion: 0,
      watermarkSyncedVersion: -1,
      watermarkMovePosition: {
        x: 0,
        y: 0
      },
      screenWidth: screen.width,
      previewHeight: screen.height
    }
  },
  computed: {
    videoModeButtonClass() {
      return this.mode === 'video' ? ['modeButton', 'modeSelected'] : ['modeButton']
    },
    photoModeButtonClass() {
      return this.mode === 'photo' ? ['modeButton', 'modeSelected'] : ['modeButton']
    },
    videoModeTextClass() {
      return this.mode === 'video' ? ['modeText', 'modeTextSelected'] : ['modeText']
    },
    photoModeTextClass() {
      return this.mode === 'photo' ? ['modeText', 'modeTextSelected'] : ['modeText']
    },
    flashPillClass() {
      return this.flashMode === 'off' ? ['flashPill'] : ['flashPill', 'flashPillActive']
    },
    flashIconClass() {
      return this.flashMode === 'off' ? ['flashIcon'] : ['flashIcon', 'flashTextActive']
    },
    flashTextClass() {
      return this.flashMode === 'off' ? ['flashText'] : ['flashText', 'flashTextActive']
    },
    flashModeText() {
      if (this.flashMode === 'on') {
        return '开'
      }
      if (this.flashMode === 'auto') {
        return '自动'
      }
      return '关'
    },
    switchCameraButtonClass() {
      const classes = ['switchCameraButton']
      if (this.cameraFacing === 'front') {
        classes.push('switchCameraButtonActive')
      }
      if (this.cameraSwitchPending) {
        classes.push('switchCameraButtonPending')
      }
      return classes
    },
    wideZoomButtonClass() {
      return this.zoomMode === 'wide' ? ['zoomButton', 'zoomButtonSelected'] : ['zoomButton']
    },
    normalZoomButtonClass() {
      return this.zoomMode === '1x' ? ['zoomButton', 'zoomButtonSelected'] : ['zoomButton']
    },
    teleZoomButtonClass() {
      return this.zoomMode === '2x' ? ['zoomButton', 'zoomButtonSelected'] : ['zoomButton']
    },
    wideZoomTextClass() {
      return this.zoomMode === 'wide' ? ['zoomText', 'zoomTextSelected'] : ['zoomText']
    },
    normalZoomTextClass() {
      return this.zoomMode === '1x' ? ['zoomText', 'zoomTextSelected'] : ['zoomText']
    },
    teleZoomTextClass() {
      return this.zoomMode === '2x' ? ['zoomText', 'zoomTextSelected'] : ['zoomText']
    },
    shutterClass() {
      const classes = ['shutter']
      if (this.mode === 'video') {
        classes.push('shutterVideo')
      }
      if (this.isRecording && !this.stopPending) {
        classes.push('shutterRecording')
      }
      return classes
    },
    shutterCoreClass() {
      if (this.isRecording && !this.stopPending) {
        return ['shutterCore', 'shutterCoreVideo', 'shutterCoreRecording']
      }
      return this.mode === 'video' ? ['shutterCore', 'shutterCoreVideo'] : ['shutterCore']
    },
    recordDotClass() {
      return this.recordBlinkOn ? ['recordDot'] : ['recordDot', 'recordDotDim']
    },
    recordElapsedText() {
      return this.formatRecordElapsed(this.recordElapsedMs)
    },
    cameraSoundPillClass() {
      return this.cameraSoundEnabled ? ['cameraSoundPill', 'cameraSoundPillActive'] : ['cameraSoundPill']
    },
    cameraSoundTextClass() {
      return this.cameraSoundEnabled ? ['cameraSoundText', 'cameraSoundTextActive'] : ['cameraSoundText']
    },
    cameraSoundModeText() {
      return this.cameraSoundEnabled ? '开' : '关'
    },
    cameraSoundIconTextClass() {
      return this.cameraSoundEnabled ? ['cameraSoundIconText', 'cameraSoundTextActive'] : ['cameraSoundIconText']
    },
    lastMediaThumbClass() {
      const classes = ['resultThumb']
      if (this.lastMediaThumbSource) {
        classes.push('resultThumbFilled')
      }
      if (this.lastMediaResult && this.lastMediaResult.kind === 'video') {
        classes.push('resultThumbVideo')
      }
      return classes
    },
    lastMediaThumbSource() {
      if (!this.lastMediaResult) {
        return ''
      }
      return this.lastMediaResult.thumbnailPath || ''
    },
    cameraViewportStyle() {
      const viewport = this.cameraViewportBounds()
      return {
        left: Math.round(viewport.left) + 'px',
        top: Math.round(viewport.top) + 'px',
        width: Math.round(viewport.width) + 'px',
        height: Math.round(viewport.height) + 'px'
      }
    },
    watermarkHasImage() {
      return this.activeWatermark && this.activeWatermark.imagePath
    },
    watermarkHasText() {
      return this.activeWatermark && (this.activeWatermark.mainTitleText || this.activeWatermark.subtitleText)
    },
    watermarkLayerStyle() {
      const layerBounds = this.watermarkLayerBounds()
      return {
        left: Math.round(layerBounds.left) + 'px',
        top: Math.round(layerBounds.top) + 'px',
        width: Math.round(layerBounds.right - layerBounds.left) + 'px',
        height: Math.round(layerBounds.bottom - layerBounds.top) + 'px'
      }
    },
    watermarkMoveX() {
      if (this.watermarkPinchActive()) {
        return 0
      }
      return this.watermarkMovePosition.x
    },
    watermarkMoveY() {
      if (this.watermarkPinchActive()) {
        return 0
      }
      return this.watermarkMovePosition.y
    },
    watermarkMoveDisabled() {
      return this.isRecording || this.stopPending
    },
    watermarkBoxStyle() {
      if (this.watermarkPinchActive()) {
        const layerBounds = this.watermarkLayerBounds()
        return {
          width: Math.round(layerBounds.right - layerBounds.left) + 'px',
          height: Math.round(layerBounds.bottom - layerBounds.top) + 'px'
        }
      }
      const frame = this.watermarkLayoutFrame()
      const metrics = this.watermarkBoxMetrics(frame.width, frame.height, frame.scale, frame.rotation)
      return {
        width: Math.round(metrics.containerWidth) + 'px',
        height: Math.round(metrics.containerHeight) + 'px'
      }
    },
    watermarkTransformStyle() {
      const frame = this.watermarkLayoutFrame()
      const metrics = this.watermarkBoxMetrics(frame.width, frame.height, frame.scale, frame.rotation)
      const scaleRatio = this.watermarkPinchScaleRatio()
      const transitionDuration = this.watermarkPinchActive() || this.watermarkTransitionDisabled ? '0ms' : '120ms'
      if (this.watermarkPinchActive()) {
        const layerBounds = this.watermarkLayerBounds()
        const centerX = frame.left + metrics.contentWidth / 2 - layerBounds.left
        const centerY = frame.top + metrics.contentHeight / 2 - layerBounds.top
        return {
          left: Math.round(centerX - metrics.boxWidth / 2) + 'px',
          top: Math.round(centerY - metrics.boxHeight / 2) + 'px',
          width: Math.round(metrics.boxWidth) + 'px',
          height: Math.round(metrics.boxHeight) + 'px',
          transformOrigin: '50% 50%',
          transform: 'rotate(' + frame.rotation + 'deg) scale(' + scaleRatio + ')',
          transitionProperty: 'left, top, width, height, transform',
          transitionDuration,
          transitionTimingFunction: 'ease-out'
        }
      }
      return {
        left: Math.round(metrics.transformLeft) + 'px',
        top: Math.round(metrics.transformTop) + 'px',
        width: Math.round(metrics.boxWidth) + 'px',
        height: Math.round(metrics.boxHeight) + 'px',
        transformOrigin: '50% 50%',
        transform: 'rotate(' + frame.rotation + 'deg) scale(' + scaleRatio + ')',
        transitionProperty: 'left, top, width, height, transform',
        transitionDuration,
        transitionTimingFunction: 'ease-out'
      }
    },
    watermarkRotateStyle() {
      return this.watermarkControlStyle(WATERMARK_HANDLE_INSET, WATERMARK_HANDLE_INSET)
    },
    watermarkDeleteStyle() {
      const frame = this.watermarkLayoutFrame()
      const metrics = this.watermarkBoxMetrics(frame.width, frame.height, frame.scale, frame.rotation)
      return this.watermarkControlStyle(metrics.boxWidth - WATERMARK_HANDLE_INSET - WATERMARK_HANDLE_SIZE, WATERMARK_HANDLE_INSET)
    },
    watermarkResizeStyle() {
      const frame = this.watermarkLayoutFrame()
      const metrics = this.watermarkBoxMetrics(frame.width, frame.height, frame.scale, frame.rotation)
      return this.watermarkControlStyle(metrics.boxWidth - WATERMARK_HANDLE_INSET - WATERMARK_HANDLE_SIZE, metrics.boxHeight - WATERMARK_HANDLE_INSET - WATERMARK_HANDLE_SIZE)
    },
    watermarkControlTextStyle() {
      const frame = this.watermarkLayoutFrame()
      return {
        transformOrigin: '50% 50%',
        transform: 'rotate(' + (-frame.rotation) + 'deg)'
      }
    },
    watermarkContentStyle() {
      if (!this.activeWatermark) {
        return {}
      }
      return {
        backgroundColor: this.activeWatermark.boxBackgroundColor,
        borderRadius: this.activeWatermark.boxRadius + 'px',
        opacity: this.activeWatermark.opacity,
        left: WATERMARK_HANDLE_PAD + 'px',
        top: WATERMARK_HANDLE_PAD + 'px',
        right: WATERMARK_HANDLE_PAD + 'px',
        bottom: WATERMARK_HANDLE_PAD + 'px',
        padding: Math.round(this.activeWatermark.boxPadding * this.watermarkLayoutFrame().scale) + 'px'
      }
    },
    watermarkImageStyle() {
      if (!this.activeWatermark) {
        return {}
      }
      return {
        width: Math.round(this.activeWatermark.imageWidth * this.watermarkLayoutFrame().scale) + 'px',
        height: Math.round(this.activeWatermark.imageHeight * this.watermarkLayoutFrame().scale) + 'px',
        marginRight: this.watermarkHasText ? Math.round(this.activeWatermark.imageTextGap * this.watermarkLayoutFrame().scale) + 'px' : '0px'
      }
    },
    watermarkMainTextStyle() {
      if (!this.activeWatermark) {
        return {}
      }
      return {
        color: this.activeWatermark.mainTitleColor,
        fontSize: Math.round(this.activeWatermark.mainTitleFontSize * this.watermarkLayoutFrame().scale) + 'px'
      }
    },
    watermarkSubTextStyle() {
      if (!this.activeWatermark) {
        return {}
      }
      return {
        color: this.activeWatermark.subtitleColor,
        fontSize: Math.round(this.activeWatermark.subtitleFontSize * this.watermarkLayoutFrame().scale) + 'px'
      }
    }
  },
  onLoad() {
    this.restoreWatermarkFromStorage()
  },
  onShow() {
    if (this.nativeReady) {
      setTimeout(() => {
        this.prepareCameraPermissions()
      }, 250)
    }
    if (this.nativeReady && this.nativeStatus === '相机权限未授权') {
      setTimeout(() => {
        this.retryCameraAfterPermission()
      }, 250)
    }
    if (this.recordStartAfterPermission) {
      this.scheduleRecordPermissionRetry()
    }
  },
  onUnload() {
    if (this.recordTimer !== null) {
      clearInterval(this.recordTimer)
      this.recordTimer = null
    }
    this.clearRecordPermissionRetry()
    this.clearRecordStartRetry()
    this.clearRecordStartPendingTimer()
    this.clearRecordStopPendingTimer()
    this.clearWatermarkPinchGesture()
    this.clearWatermarkSyncTimer()
    this.clearWatermarkTransitionTimer()
  },
  beforeDestroy() {
    if (this.recordTimer !== null) {
      clearInterval(this.recordTimer)
      this.recordTimer = null
    }
    this.clearRecordPermissionRetry()
    this.clearRecordStartRetry()
    this.clearRecordStartPendingTimer()
    this.clearRecordStopPendingTimer()
    this.clearWatermarkPinchGesture()
    this.clearWatermarkSyncTimer()
    this.clearWatermarkTransitionTimer()
  },
  methods: {
    resolveNativeCamera() {
      return this.$refs.nativeCamera || null
    },
    eventDetail(event) {
      if (event && event.detail) {
        return event.detail
      }
      return event || {}
    },
    applyNativeCameraState(detail) {
      if (!detail) {
        return
      }
      if (detail.cameraFacing) {
        this.cameraFacing = detail.cameraFacing
      }
      if (detail.flashMode) {
        this.flashMode = detail.flashMode
      }
      if (detail.zoomMode) {
        this.zoomMode = detail.zoomMode
      }
    },
    normalizeNativeResult(result, fallbackMessage) {
      let nativeResult = result
      if (typeof result === 'string') {
        nativeResult = this.parseNativeResultText(result, fallbackMessage)
      } else if (nativeResult && typeof nativeResult.get !== 'function' && typeof nativeResult.success === 'undefined' && typeof nativeResult.toString === 'function') {
        const nativeText = nativeResult.toString()
        if (typeof nativeText === 'string' && nativeText.trim().indexOf('{') === 0) {
          nativeResult = this.parseNativeResultText(nativeText, fallbackMessage)
        }
      }
      if (nativeResult && typeof nativeResult.get === 'function') {
        const rawData = nativeResult.get('data')
        nativeResult = {
          success: nativeResult.get('success') === true,
          errorCode: nativeResult.get('errorCode') || '',
          errorMessage: nativeResult.get('errorMessage') || '',
          nativeMessage: nativeResult.get('nativeMessage') || '',
          data: rawData || {}
        }
      }
      if (nativeResult && nativeResult.success === true) {
        return nativeResult
      }
      if (nativeResult && nativeResult.success === false) {
        return nativeResult
      }
      return {
        success: false,
        errorCode: '9001',
        errorMessage: fallbackMessage || '原生相机未返回有效结果',
        data: {}
      }
    },
    parseNativeResultText(text, fallbackMessage) {
      try {
        return JSON.parse(text)
      } catch (error) {
        return {
          success: false,
          errorCode: '9001',
          errorMessage: fallbackMessage || '原生相机未返回有效结果',
          nativeMessage: error && error.message ? error.message : '',
          data: {}
        }
      }
    },
    nativeReturnIsEmpty(result) {
      return result === null || typeof result === 'undefined' || typeof result === 'number' || (typeof result === 'string' && result.trim() === '')
    },
    triggerHaptic(type) {
      try {
        if (typeof uni !== 'undefined' && typeof uni.vibrateShort === 'function') {
          uni.vibrateShort({ type: type || 'light' })
        }
      } catch (error) {
      }
    },
    acceptedNativeResult(message) {
      return {
        success: true,
        errorCode: '',
        errorMessage: '',
        nativeMessage: '',
        data: {
          message: message || ''
        }
      }
    },
    async normalizeNativeCommandReturn(result, fallbackMessage, acceptedMessage, watchedErrorCodes) {
      if (this.nativeReturnIsEmpty(result)) {
        return await this.waitForNativeCommandResult(fallbackMessage, acceptedMessage, watchedErrorCodes || [])
      }
      return this.normalizeNativeResult(result, fallbackMessage)
    },
    waitForNativeCommandResult(fallbackMessage, acceptedMessage, watchedErrorCodes) {
      const startedAt = Date.now()
      return new Promise((resolve) => {
        setTimeout(() => {
          const lastError = this.lastNativeError || null
          if (lastError && lastError.at >= startedAt && this.nativeErrorMatches(lastError.errorCode, watchedErrorCodes)) {
            resolve({
              success: false,
              errorCode: lastError.errorCode || '',
              errorMessage: lastError.errorMessage || fallbackMessage || '原生相机未返回有效结果',
              nativeMessage: lastError.nativeMessage || '',
              data: {}
            })
            return
          }
          resolve(this.acceptedNativeResult(acceptedMessage))
        }, 160)
      })
    },
    nativeErrorMatches(errorCode, watchedErrorCodes) {
      if (!watchedErrorCodes || watchedErrorCodes.length === 0) {
        return true
      }
      for (let i = 0; i < watchedErrorCodes.length; i += 1) {
        if (errorCode === watchedErrorCodes[i] || (errorCode && errorCode.indexOf(watchedErrorCodes[i]) === 0)) {
          return true
        }
      }
      return false
    },
    handleNativeReady() {
      this.nativeReady = true
      this.nativeStatus = '相机组件已加载'
      setTimeout(() => {
        this.prepareCameraPermissions()
        this.syncWatermarkToNative(false)
      }, 120)
    },
    async handleCameraReady(event) {
      const detail = this.eventDetail(event)
      this.applyNativeCameraState(detail)
      this.nativeStatus = detail.message || '相机已准备'
      const flashApplied = await this.syncFlashMode(this.flashMode, true)
      if (!flashApplied) {
        this.flashMode = 'off'
      }
      const zoomApplied = await this.syncZoomMode(this.zoomMode, true)
      if (!zoomApplied) {
        this.zoomMode = detail.zoomMode || '1x'
      }
      this.syncWatermarkToNative(false)
      setTimeout(async () => {
        await this.prepareRecordPermissions(true)
      }, 180)
    },
    handleNativeError(event) {
      const detail = this.eventDetail(event)
      this.lastNativeError = {
        errorCode: detail.errorCode || '',
        errorMessage: detail.errorMessage || '相机错误',
        nativeMessage: detail.nativeMessage || '',
        at: Date.now()
      }
      if (detail && detail.errorCode === '1501') {
        return
      }
      if (detail && detail.errorCode === '1003' && this.recordStartAfterPermission) {
        return
      }
      if (this.stopPending && detail && detail.errorCode && detail.errorCode.indexOf('14') === 0) {
        this.stopRecordingClock()
        this.clearRecordStopPendingTimer()
        this.isRecording = false
        this.stopPending = false
      }
      if (this.recordStartPending) {
        this.stopRecordingClock()
        this.clearRecordStartPendingTimer()
        this.recordStartPending = false
        this.isRecording = false
      }
      this.nativeStatus = detail.errorMessage || '相机错误'
    },
    handlePhotoDone(event) {
      const detail = this.eventDetail(event)
      this.rememberMediaResult('photo', detail)
      this.nativeStatus = detail.message || '照片已保存到相册'
    },
    handleRecordStart(event) {
      const detail = this.eventDetail(event)
      if (!this.isRecording || this.recordTimer === null) {
        this.startRecordingClock()
      }
      this.isRecording = true
      this.clearRecordStartPendingTimer()
      this.recordStartPending = false
      this.stopPending = false
      this.nativeStatus = detail.message || '录像中'
    },
    handleRecordDone(event) {
      const detail = this.eventDetail(event)
      this.stopRecordingClock()
      this.isRecording = false
      this.clearRecordStartPendingTimer()
      this.clearRecordStopPendingTimer()
      this.recordStartPending = false
      this.stopPending = false
      this.rememberMediaResult('video', detail)
      this.nativeStatus = detail.message || (detail.savedToAlbum === true ? '视频已保存到相册' : '视频已生成')
    },
    handleFlashChange(event) {
      const detail = this.eventDetail(event)
      const silent = this.flashRequestSilent === true
      this.flashEventHandled = true
      this.flashEventApplied = detail.applied !== false
      this.flashRequestSilent = false
      if (detail.applied === false && detail.requestedFlashMode !== 'off') {
        this.nativeStatus = detail.message || '当前设备不支持该闪光灯模式'
        return
      }
      if (detail.flashMode) {
        this.flashMode = detail.flashMode
      }
      if (silent !== true && detail.message) {
        this.nativeStatus = detail.message
      }
    },
    handleZoomChange(event) {
      const detail = this.eventDetail(event)
      const silent = this.zoomRequestSilent === true
      this.zoomEventHandled = true
      this.zoomEventApplied = detail.applied !== false
      this.zoomRequestSilent = false
      if (detail.applied === false && detail.requestedZoomMode) {
        if (silent !== true) {
          this.nativeStatus = detail.message || '当前设备不支持该焦段'
        }
        return
      }
      if (detail.zoomMode) {
        this.zoomMode = detail.zoomMode
      }
      if (silent !== true && detail.message) {
        this.nativeStatus = detail.message
      }
    },
    handleCameraChange(event) {
      const detail = this.eventDetail(event)
      this.applyNativeCameraState(detail)
      if (detail.applied === false) {
        this.nativeStatus = detail.message || '当前设备不支持切换摄像头'
        return
      }
      this.nativeStatus = detail.message || this.cameraFacingLabel(this.cameraFacing)
    },
    restoreWatermarkFromStorage() {
      const stored = uni.getStorageSync(WATERMARK_STORAGE_KEY)
      if (stored && stored.templateId) {
        this.applyWatermarkTemplate(stored)
      }
    },
    openWatermarkSheet() {
      if (this.isRecording || this.stopPending) {
        this.nativeStatus = '录像中不能编辑水印'
        return
      }
      this.showWatermarkSheet = true
    },
    closeWatermarkSheet() {
      this.showWatermarkSheet = false
    },
    async openSystemAlbum() {
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.openSystemAlbum !== 'function') {
        this.nativeStatus = '原生相册接口不可用'
        return
      }
      const mediaUri = this.lastMediaResult ? (this.lastMediaResult.albumUri || this.lastMediaResult.path || '') : ''
      try {
        const result = this.normalizeNativeResult(await nativeCamera.openSystemAlbum(mediaUri), '打开系统相册失败')
        if (!result.success) {
          this.nativeStatus = result.errorMessage || '打开系统相册失败'
          return
        }
        this.nativeStatus = result.data && result.data.message ? result.data.message : '已打开系统相册'
      } catch (error) {
        this.nativeStatus = error && error.message ? error.message : '打开系统相册失败'
      }
    },
    rememberMediaResult(kind, detail) {
      const source = detail || {}
      const createdAt = Date.now()
      const path = source.albumUri || source.albumPath || source.tempFilePath || source.path || ''
      const savedToAlbum = source.savedToAlbum === true
      const statusText = source.message || (savedToAlbum ? '已保存到相册' : '已生成，相册保存失败')
      const nextItem = {
        id: kind + '-' + createdAt + '-' + this.recentMediaResults.length,
        kind,
        title: kind === 'photo' ? '照片' : '视频',
        statusText,
        path,
        albumUri: source.albumUri || '',
        albumPath: source.albumPath || '',
        thumbnailPath: this.pickMediaThumbnailPath(kind, source, path),
        pathText: path || '暂无路径',
        timeText: this.formatMediaResultTime(createdAt)
      }
      const nextResults = [nextItem].concat(this.recentMediaResults)
      this.lastMediaResult = nextItem
      this.recentMediaResults = nextResults.slice(0, RESULT_CACHE_LIMIT)
    },
    pickMediaThumbnailPath(kind, source, fallbackPath) {
      if (source.thumbnailPath) {
        return source.thumbnailPath
      }
      if (source.thumbnailUri) {
        return source.thumbnailUri
      }
      if (kind === 'photo') {
        return source.tempFilePath || source.path || source.albumPath || source.albumUri || fallbackPath || ''
      }
      return ''
    },
    formatMediaResultTime(timestamp) {
      const date = new Date(timestamp)
      const hours = date.getHours()
      const minutes = date.getMinutes()
      const hourText = hours < 10 ? '0' + hours : '' + hours
      const minuteText = minutes < 10 ? '0' + minutes : '' + minutes
      return hourText + ':' + minuteText
    },
    selectWatermarkTemplate(template) {
      if (this.isRecording || this.stopPending) {
        this.nativeStatus = '录像中不能编辑水印'
        return
      }
      const nextTemplate = cloneTemplate(template)
      this.applyWatermarkTemplate(nextTemplate)
      uni.setStorageSync(WATERMARK_STORAGE_KEY, nextTemplate)
      this.showWatermarkSheet = false
      this.syncWatermarkToNative(false)
    },
    applyWatermarkTemplate(template) {
      const nextTemplate = cloneTemplate(template)
      this.clearWatermarkSyncTimer()
      this.clearWatermarkTransitionTimer()
      this.watermarkTransitionDisabled = true
      this.clearWatermarkPinchGesture()
      this.watermarkMoveActive = false
      this.watermarkMoveDraft = null
      const viewport = this.cameraViewportBounds()
      const defaultSize = this.watermarkTemplateFrameSize(nextTemplate, viewport)
      const initialLeft = viewport.left + viewport.width * (nextTemplate.positionX || 0.12)
      const initialTop = viewport.top + viewport.height * (nextTemplate.positionY || 0.16)
      const initialScale = nextTemplate.scale || 1
      const initialRotation = normalizeRotation(nextTemplate.rotation || 0)
      const clamped = this.clampWatermarkFrame(initialLeft, initialTop, initialScale, initialRotation, defaultSize.width, defaultSize.height)
      this.watermarkFrame = {
        left: clamped.left,
        top: clamped.top,
        width: defaultSize.width,
        height: defaultSize.height,
        scale: clamped.scale,
        rotation: clamped.rotation
      }
      this.watermarkMovePosition = this.watermarkMovePositionFromFrame()
      this.watermarkRenderKey += 1
      this.activeWatermark = nextTemplate
      this.watermarkSyncVersion += 1
      this.traceWatermarkGeometry('template-applied', this.watermarkFrame, {
        moveX: this.watermarkMovePosition.x,
        moveY: this.watermarkMovePosition.y
      })
      this.watermarkTransitionTimer = setTimeout(() => {
        this.watermarkTransitionTimer = null
        this.watermarkTransitionDisabled = false
      }, 180)
    },
    clearActiveWatermark() {
      if (this.isRecording || this.stopPending) {
        this.nativeStatus = '录像中不能编辑水印'
        return
      }
      this.clearWatermarkPinchGesture()
      this.clearWatermarkSyncTimer()
      this.clearWatermarkTransitionTimer()
      this.watermarkTransitionDisabled = false
      this.watermarkPinchGesture = null
      this.watermarkMoveActive = false
      this.watermarkMoveDraft = null
      this.watermarkSyncVersion += 1
      this.activeWatermark = null
      uni.removeStorageSync(WATERMARK_STORAGE_KEY)
      const nativeCamera = this.resolveNativeCamera()
      if (nativeCamera && typeof nativeCamera.clearWatermark === 'function') {
        nativeCamera.clearWatermark()
        this.watermarkSyncedVersion = this.watermarkSyncVersion
      }
    },
    stopWatermarkTouch() {
    },
    startWatermarkTouch(event) {
      if (this.isRecording || this.stopPending || !this.activeWatermark) {
        return
      }
      const touchPair = this.watermarkTouchPair(event, true)
      if (touchPair) {
        this.startWatermarkPinch(touchPair)
        return
      }
      this.clearWatermarkPinchGesture()
      this.startWatermarkMove()
    },
    moveWatermarkTouch(event) {
      if (this.isRecording || this.stopPending || !this.activeWatermark) {
        return
      }
      const touchPair = this.watermarkTouchPair(event, true)
      if (!touchPair) {
        return
      }
      if (!this.watermarkPinchGesture) {
        this.startWatermarkPinch(touchPair)
        return
      }
      this.updateWatermarkPinch(touchPair)
    },
    finishWatermarkTouch(event) {
      if (this.watermarkPinchGesture) {
        const touchPair = this.watermarkTouchPair(event, false)
        if (touchPair) {
          this.updateWatermarkPinch(touchPair)
          return
        }
        this.finishWatermarkPinch()
        return
      }
      this.finishWatermarkMove()
    },
    startWatermarkMove() {
      if (this.isRecording || this.stopPending || !this.activeWatermark) {
        return
      }
      this.watermarkMoveActive = true
      this.watermarkMoveDraft = null
    },
    rotateWatermarkQuarterTurn() {
      if (this.isRecording || this.stopPending || !this.activeWatermark) {
        this.nativeStatus = '录像中不能编辑水印'
        return
      }
      this.clearWatermarkPinchGesture()
      const nextRotation = normalizeRotation(this.watermarkFrame.rotation + 90)
      const clamped = this.clampWatermarkFrame(this.watermarkFrame.left, this.watermarkFrame.top, this.watermarkFrame.scale, nextRotation)
      this.updateWatermarkFrame({
        left: clamped.left,
        top: clamped.top,
        scale: clamped.scale,
        rotation: clamped.rotation
      })
      this.flushWatermarkSync(false)
    },
    updateWatermarkFrame(patch) {
      const nextWidth = typeof patch.width === 'number' ? patch.width : this.watermarkFrame.width
      const nextHeight = typeof patch.height === 'number' ? patch.height : this.watermarkFrame.height
      const clamped = this.clampWatermarkFrame(
        typeof patch.left === 'number' ? patch.left : this.watermarkFrame.left,
        typeof patch.top === 'number' ? patch.top : this.watermarkFrame.top,
        typeof patch.scale === 'number' ? patch.scale : this.watermarkFrame.scale,
        typeof patch.rotation === 'number' ? patch.rotation : this.watermarkFrame.rotation,
        nextWidth,
        nextHeight
      )
      this.watermarkFrame = {
        left: clamped.left,
        top: clamped.top,
        width: nextWidth,
        height: nextHeight,
        scale: clamped.scale,
        rotation: clamped.rotation
      }
      this.watermarkMovePosition = this.watermarkMovePositionFromFrame()
      this.watermarkSyncVersion += 1
    },
    scheduleWatermarkSync() {
      if (!this.activeWatermark || this.isRecording || this.stopPending) {
        return
      }
      this.clearWatermarkSyncTimer()
      this.watermarkSyncTimer = setTimeout(() => {
        this.watermarkSyncTimer = null
        this.syncWatermarkToNative(false)
      }, 160)
    },
    async flushWatermarkSync(showError) {
      this.clearWatermarkSyncTimer()
      return await this.syncWatermarkToNative(showError === true)
    },
    clearWatermarkSyncTimer() {
      if (this.watermarkSyncTimer !== null) {
        clearTimeout(this.watermarkSyncTimer)
        this.watermarkSyncTimer = null
      }
    },
    clearWatermarkTransitionTimer() {
      if (this.watermarkTransitionTimer !== null) {
        clearTimeout(this.watermarkTransitionTimer)
        this.watermarkTransitionTimer = null
      }
    },
    watermarkControlStyle(left, top) {
      return {
        left: Math.round(left) + 'px',
        top: Math.round(top) + 'px'
      }
    },
    async syncWatermarkToNative(showError) {
      const syncVersion = this.watermarkSyncVersion
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.setWatermark !== 'function') {
        if (showError === true) {
          this.nativeStatus = '原生水印接口不可用'
        }
        return false
      }
      if (this.watermarkSyncedVersion === syncVersion) {
        return true
      }
      if (!this.activeWatermark) {
        if (typeof nativeCamera.clearWatermark === 'function') {
          nativeCamera.clearWatermark()
        }
        this.watermarkSyncedVersion = syncVersion
        return true
      }
      const payload = await this.buildNativeWatermarkPayload()
      if (syncVersion !== this.watermarkSyncVersion || !this.activeWatermark) {
        return true
      }
      try {
        const result = await this.normalizeNativeCommandReturn(await nativeCamera.setWatermark(payload), '水印设置失败', '水印已更新', ['12', '14'])
        if (!result.success && showError === true) {
          this.nativeStatus = result.errorMessage || '水印设置失败'
        }
        if (result.success === true) {
          this.watermarkSyncedVersion = syncVersion
        }
        return result.success === true
      } catch (error) {
        if (showError === true) {
          this.nativeStatus = error && error.message ? error.message : '水印设置失败'
        }
        return false
      }
    },
    async buildNativeWatermarkPayload() {
      const template = cloneTemplate(this.activeWatermark)
      const frame = this.watermarkInteractionFrame()
      const viewport = this.cameraViewportBounds()
      const effectiveWidth = Math.max(1, Math.round(frame.width * frame.scale))
      const effectiveHeight = Math.max(1, Math.round(frame.height * frame.scale))
      const payloadLeft = this.clampNumber(frame.left, viewport.left, viewport.right - effectiveWidth)
      const payloadTop = this.clampNumber(frame.top, viewport.top, viewport.bottom - effectiveHeight)
      template.positionX = (payloadLeft - viewport.left) / viewport.width
      template.positionY = (payloadTop - viewport.top) / viewport.height
      template.boxWidth = effectiveWidth / viewport.width
      template.boxHeight = effectiveHeight / viewport.height
      template.scale = 1
      template.imageWidth = template.imageWidth * frame.scale
      template.imageHeight = template.imageHeight * frame.scale
      template.imageTextGap = template.imageTextGap * frame.scale
      template.mainTitleFontSize = template.mainTitleFontSize * frame.scale
      template.subtitleFontSize = template.subtitleFontSize * frame.scale
      template.boxPadding = template.boxPadding * frame.scale
      template.boxRadius = template.boxRadius * frame.scale
      template.rotation = frame.rotation
      template.previewWidth = viewport.width
      template.previewHeight = viewport.height
      template.nativeImagePath = await this.resolveNativeImagePath(template.imagePath)
      return template
    },
    resolveNativeImagePath(path) {
      if (!path) {
        return Promise.resolve('')
      }
      return new Promise((resolve) => {
        uni.getImageInfo({
          src: path,
          success: (res) => {
            resolve(res.path || path)
          },
          fail: () => {
            resolve(path)
          }
        })
      })
    },
    handleWatermarkMoveChange(event) {
      if (this.isRecording || this.stopPending || !this.activeWatermark) {
        return
      }
      const detail = event && event.detail ? event.detail : {}
      const moveX = this.pickMoveNumber(detail, 'x')
      const moveY = this.pickMoveNumber(detail, 'y')
      if (this.watermarkPinchGesture) {
        this.watermarkMoveActive = false
        this.watermarkMoveDraft = null
        if (moveX !== null && moveY !== null) {
          this.traceWatermarkGeometry('pinch-native-change', this.watermarkPinchPreviewFrame() || this.watermarkFrame, {
            nativeX: moveX,
            nativeY: moveY
          })
        }
        return
      }
      if (moveX === null || moveY === null) {
        return
      }
      if (!this.watermarkMoveActive) {
        return
      }
      this.watermarkMoveDraft = {
        x: moveX,
        y: moveY
      }
      this.watermarkMovePosition = {
        x: moveX,
        y: moveY
      }
      this.traceWatermarkGeometry('drag-change', this.watermarkFrameFromMovePosition(moveX, moveY, this.watermarkFrame), {
        moveX,
        moveY
      })
    },
    commitWatermarkMoveDraft(flushNow) {
      if (!this.watermarkMoveDraft || !this.activeWatermark || this.isRecording || this.stopPending) {
        this.watermarkMoveActive = false
        this.watermarkMoveDraft = null
        return
      }
      const moveX = this.watermarkMoveDraft.x
      const moveY = this.watermarkMoveDraft.y
      const nextFrame = this.watermarkFrameFromMovePosition(moveX, moveY, this.watermarkFrame)
      this.watermarkMoveActive = false
      this.watermarkMoveDraft = null
      if (Math.abs(nextFrame.left - this.watermarkFrame.left) < 0.5 && Math.abs(nextFrame.top - this.watermarkFrame.top) < 0.5) {
        return
      }
      this.traceWatermarkGeometry('drag-commit', {
        left: nextFrame.left,
        top: nextFrame.top,
        width: this.watermarkFrame.width,
        height: this.watermarkFrame.height,
        scale: this.watermarkFrame.scale,
        rotation: this.watermarkFrame.rotation
      }, {
        moveX,
        moveY
      })
      this.updateWatermarkFrame({
        left: nextFrame.left,
        top: nextFrame.top,
        scale: this.watermarkFrame.scale,
        rotation: this.watermarkFrame.rotation
      })
      if (flushNow === true) {
        this.flushWatermarkSync(false)
      }
    },
    finishWatermarkMove() {
      if (!this.activeWatermark || this.isRecording || this.stopPending) {
        return
      }
      this.commitWatermarkMoveDraft(true)
    },
    startWatermarkPinch(touchPair) {
      const distance = this.pinchDistance(touchPair)
      if (distance < WATERMARK_PINCH_MIN_DISTANCE) {
        return
      }
      this.commitWatermarkMoveDraft(false)
      this.clearWatermarkSyncTimer()
      const frame = this.watermarkVisibleFrame()
      const size = this.watermarkContentSize(frame.width, frame.height, frame.scale)
      const startFrame = {
        left: frame.left,
        top: frame.top,
        width: frame.width,
        height: frame.height,
        scale: frame.scale,
        rotation: frame.rotation
      }
      this.watermarkMoveActive = false
      this.watermarkMoveDraft = null
      this.watermarkPinchGesture = {
        startDistance: distance,
        startScale: startFrame.scale,
        centerX: frame.left + size.width / 2,
        centerY: frame.top + size.height / 2,
        width: startFrame.width,
        height: startFrame.height,
        rotation: startFrame.rotation,
        startFrame,
        lastScale: startFrame.scale,
        previewScaleRatio: 1,
        commitFrame: null,
        pendingFrame: null,
        lastUpdateAt: 0,
        changed: false
      }
      this.traceWatermarkGeometry('pinch-start', startFrame, {
        distance,
        moveX: this.watermarkMovePositionFromFrame(startFrame).x,
        moveY: this.watermarkMovePositionFromFrame(startFrame).y
      })
    },
    updateWatermarkPinch(touchPair) {
      if (!this.watermarkPinchGesture) {
        return
      }
      const nextUpdate = this.buildWatermarkPinchUpdate(touchPair)
      if (!nextUpdate) {
        return
      }
      const now = Date.now()
      if (this.watermarkPinchGesture.lastUpdateAt > 0 && now - this.watermarkPinchGesture.lastUpdateAt < WATERMARK_PINCH_FRAME_INTERVAL_MS) {
        this.watermarkPinchGesture = {
          ...this.watermarkPinchGesture,
          pendingFrame: nextUpdate
        }
        return
      }
      this.applyWatermarkPinchUpdate(nextUpdate, now)
    },
    buildWatermarkPinchUpdate(touchPair) {
      if (!this.watermarkPinchGesture) {
        return null
      }
      const distance = this.pinchDistance(touchPair)
      if (distance < WATERMARK_PINCH_MIN_DISTANCE) {
        return null
      }
      const ratio = distance / this.watermarkPinchGesture.startDistance
      const rawScale = this.watermarkPinchGesture.startScale * ratio
      const nextLeft = this.watermarkPinchGesture.centerX - this.watermarkPinchGesture.width * rawScale / 2
      const nextTop = this.watermarkPinchGesture.centerY - this.watermarkPinchGesture.height * rawScale / 2
      const maxScale = this.maxWatermarkScale(nextLeft, nextTop, this.watermarkPinchGesture.rotation, this.watermarkPinchGesture.width, this.watermarkPinchGesture.height)
      const previousScale = typeof this.watermarkPinchGesture.lastScale === 'number' ? this.watermarkPinchGesture.lastScale : this.watermarkPinchGesture.startScale
      const nextScale = this.limitWatermarkPinchScale(rawScale, previousScale, Math.min(WATERMARK_MIN_SCALE, maxScale), maxScale)
      const clamped = this.clampWatermarkFrame(
        this.watermarkPinchGesture.centerX - this.watermarkPinchGesture.width * nextScale / 2,
        this.watermarkPinchGesture.centerY - this.watermarkPinchGesture.height * nextScale / 2,
        nextScale,
        this.watermarkPinchGesture.rotation,
        this.watermarkPinchGesture.width,
        this.watermarkPinchGesture.height
      )
      return {
        previewScaleRatio: clamped.scale / this.watermarkPinchGesture.startScale,
        rawScale: rawScale,
        appliedScale: nextScale,
        commitFrame: {
          left: clamped.left,
          top: clamped.top,
          scale: clamped.scale,
          rotation: clamped.rotation
        }
      }
    },
    applyWatermarkPinchUpdate(update, updateAt) {
      if (!this.watermarkPinchGesture || !update) {
        return
      }
      this.watermarkPinchGesture = {
        ...this.watermarkPinchGesture,
        previewScaleRatio: update.previewScaleRatio,
        commitFrame: update.commitFrame,
        lastScale: update.commitFrame.scale,
        pendingFrame: null,
        lastUpdateAt: updateAt,
        changed: true
      }
      const traceFrame = {
        left: update.commitFrame.left,
        top: update.commitFrame.top,
        width: this.watermarkPinchGesture.startFrame.width,
        height: this.watermarkPinchGesture.startFrame.height,
        scale: update.commitFrame.scale,
        rotation: update.commitFrame.rotation
      }
      this.traceWatermarkGeometry('pinch-update', traceFrame, {
        ratio: update.previewScaleRatio,
        rawScale: update.rawScale,
        appliedScale: update.appliedScale
      })
    },
    finishWatermarkPinch() {
      if (this.watermarkPinchGesture && this.watermarkPinchGesture.pendingFrame) {
        const shouldApplyPending = this.watermarkPinchGesture.lastUpdateAt <= 0 || Date.now() - this.watermarkPinchGesture.lastUpdateAt >= WATERMARK_PINCH_FRAME_INTERVAL_MS
        if (shouldApplyPending) {
          this.applyWatermarkPinchUpdate(this.watermarkPinchGesture.pendingFrame, Date.now())
        }
      }
      const gesture = this.watermarkPinchGesture
      const changed = gesture && gesture.changed === true
      const commitFrame = gesture ? gesture.commitFrame : null
      this.watermarkMoveActive = false
      this.watermarkMoveDraft = null
      if (changed && commitFrame) {
        this.traceWatermarkGeometry('pinch-commit', {
          left: commitFrame.left,
          top: commitFrame.top,
          width: gesture.startFrame.width,
          height: gesture.startFrame.height,
          scale: commitFrame.scale,
          rotation: commitFrame.rotation
        })
        this.updateWatermarkFrame(commitFrame)
        this.clearWatermarkPinchGesture()
        this.flushWatermarkSync(false)
        return
      }
      this.clearWatermarkPinchGesture()
    },
    clearWatermarkPinchGesture() {
      this.watermarkPinchGesture = null
    },
    watermarkTouchPair(event, includeChangedTouches) {
      const groups = []
      if (event && event.touches) {
        groups.push(event.touches)
      }
      if (event && event.detail && event.detail.touches) {
        groups.push(event.detail.touches)
      }
      if (includeChangedTouches === true && event && event.changedTouches) {
        groups.push(event.changedTouches)
      }
      if (includeChangedTouches === true && event && event.detail && event.detail.changedTouches) {
        groups.push(event.detail.changedTouches)
      }
      for (let i = 0; i < groups.length; i += 1) {
        const group = groups[i]
        if (group && group.length >= 2) {
          return {
            first: this.touchPointFromSource(group[0]),
            second: this.touchPointFromSource(group[1])
          }
        }
      }
      return null
    },
    touchPointFromSource(touch) {
      return {
        x: this.pickTouchCoordinate(touch, ['pageX', 'clientX', 'screenX', 'x']),
        y: this.pickTouchCoordinate(touch, ['pageY', 'clientY', 'screenY', 'y'])
      }
    },
    pickTouchCoordinate(touch, names) {
      for (let i = 0; i < names.length; i += 1) {
        const value = touch ? touch[names[i]] : null
        if (typeof value === 'number') {
          return value
        }
        if (typeof value === 'string' && value.length > 0) {
          const numberValue = parseFloat(value)
          if (!isNaN(numberValue)) {
            return numberValue
          }
        }
      }
      return 0
    },
    pinchDistance(touchPair) {
      const x = touchPair.first.x - touchPair.second.x
      const y = touchPair.first.y - touchPair.second.y
      return Math.sqrt(x * x + y * y)
    },
    pickMoveNumber(source, name) {
      const value = source ? source[name] : null
      if (typeof value === 'number') {
        return value
      }
      if (typeof value === 'string' && value.length > 0) {
        const numberValue = parseFloat(value)
        if (!isNaN(numberValue)) {
          return numberValue
        }
      }
      return null
    },
    watermarkVisibleFrame() {
      return this.watermarkFrame
    },
    watermarkInteractionFrame() {
      const pinchFrame = this.watermarkPinchPreviewFrame()
      if (pinchFrame) {
        return pinchFrame
      }
      if (this.watermarkMoveDraft && this.activeWatermark) {
        const movedFrame = this.watermarkFrameFromMovePosition(this.watermarkMoveDraft.x, this.watermarkMoveDraft.y, this.watermarkFrame)
        return {
          left: movedFrame.left,
          top: movedFrame.top,
          width: this.watermarkFrame.width,
          height: this.watermarkFrame.height,
          scale: this.watermarkFrame.scale,
          rotation: this.watermarkFrame.rotation
        }
      }
      return this.watermarkFrame
    },
    traceWatermarkGeometry(stage, frame, extra) {
      if (!WATERMARK_TRACE_LOG || !frame) {
        return
      }
      const traceFrame = {
        left: typeof frame.left === 'number' ? frame.left : this.watermarkFrame.left,
        top: typeof frame.top === 'number' ? frame.top : this.watermarkFrame.top,
        width: typeof frame.width === 'number' ? frame.width : this.watermarkFrame.width,
        height: typeof frame.height === 'number' ? frame.height : this.watermarkFrame.height,
        scale: typeof frame.scale === 'number' ? frame.scale : this.watermarkFrame.scale,
        rotation: typeof frame.rotation === 'number' ? frame.rotation : this.watermarkFrame.rotation
      }
      const frameMove = this.watermarkMovePositionFromFrame(traceFrame)
      const renderX = extra && typeof extra.moveX === 'number' ? extra.moveX : this.watermarkMoveX
      const renderY = extra && typeof extra.moveY === 'number' ? extra.moveY : this.watermarkMoveY
      const metrics = this.watermarkBoxMetrics(traceFrame.width, traceFrame.height, traceFrame.scale, traceFrame.rotation)
      const layerBounds = this.watermarkLayerBounds()
      const rootWidth = this.watermarkPinchActive()
        ? layerBounds.right - layerBounds.left
        : metrics.containerWidth
      const rootHeight = this.watermarkPinchActive()
        ? layerBounds.bottom - layerBounds.top
        : metrics.containerHeight
      const innerLeft = this.watermarkPinchActive()
        ? traceFrame.left + metrics.contentWidth / 2 - layerBounds.left - metrics.boxWidth / 2
        : metrics.transformLeft
      const innerTop = this.watermarkPinchActive()
        ? traceFrame.top + metrics.contentHeight / 2 - layerBounds.top - metrics.boxHeight / 2
        : metrics.transformTop
      const parts = [
        '[WATERMARK_TRACE]',
        stage,
        'rootX=' + this.formatTraceNumber(renderX),
        'rootY=' + this.formatTraceNumber(renderY),
        'rootW=' + this.formatTraceNumber(rootWidth),
        'rootH=' + this.formatTraceNumber(rootHeight),
        'frameX=' + this.formatTraceNumber(frameMove.x),
        'frameY=' + this.formatTraceNumber(frameMove.y),
        'frameLeft=' + this.formatTraceNumber(traceFrame.left),
        'frameTop=' + this.formatTraceNumber(traceFrame.top),
        'frameW=' + this.formatTraceNumber(traceFrame.width),
        'frameH=' + this.formatTraceNumber(traceFrame.height),
        'scale=' + this.formatTraceNumber(traceFrame.scale),
        'rotation=' + this.formatTraceNumber(traceFrame.rotation),
        'contentW=' + this.formatTraceNumber(metrics.contentWidth),
        'contentH=' + this.formatTraceNumber(metrics.contentHeight),
        'boxW=' + this.formatTraceNumber(metrics.boxWidth),
        'boxH=' + this.formatTraceNumber(metrics.boxHeight),
        'containerW=' + this.formatTraceNumber(metrics.containerWidth),
        'containerH=' + this.formatTraceNumber(metrics.containerHeight),
        'innerX=' + this.formatTraceNumber(innerLeft),
        'innerY=' + this.formatTraceNumber(innerTop),
        'innerW=' + this.formatTraceNumber(metrics.boxWidth),
        'innerH=' + this.formatTraceNumber(metrics.boxHeight)
      ]
      if (extra) {
        if (typeof extra.moveX === 'number') {
          parts.push('moveX=' + this.formatTraceNumber(extra.moveX))
        }
        if (typeof extra.moveY === 'number') {
          parts.push('moveY=' + this.formatTraceNumber(extra.moveY))
        }
        if (typeof extra.distance === 'number') {
          parts.push('distance=' + this.formatTraceNumber(extra.distance))
        }
        if (typeof extra.ratio === 'number') {
          parts.push('ratio=' + this.formatTraceNumber(extra.ratio))
        }
        if (typeof extra.rawScale === 'number') {
          parts.push('rawScale=' + this.formatTraceNumber(extra.rawScale))
        }
        if (typeof extra.appliedScale === 'number') {
          parts.push('appliedScale=' + this.formatTraceNumber(extra.appliedScale))
        }
        if (typeof extra.nativeX === 'number') {
          parts.push('nativeX=' + this.formatTraceNumber(extra.nativeX))
        }
        if (typeof extra.nativeY === 'number') {
          parts.push('nativeY=' + this.formatTraceNumber(extra.nativeY))
        }
      }
      this.writeWatermarkTrace(parts.join(' '))
    },
    writeWatermarkTrace(message) {
      console.log(message)
      try {
        if (typeof plus !== 'undefined' && plus && plus.android) {
          if (!watermarkTraceAndroidLog) {
            watermarkTraceAndroidLog = plus.android.importClass('android.util.Log')
          }
          watermarkTraceAndroidLog.i('WATERMARK_TRACE', message)
        }
      } catch (error) {
      }
    },
    formatTraceNumber(value) {
      return Math.round(value * 1000) / 1000
    },
    watermarkPinchActive() {
      return this.watermarkPinchGesture !== null
    },
    watermarkLayoutFrame() {
      const pinchFrame = this.watermarkPinchPreviewFrame()
      if (pinchFrame) {
        return pinchFrame
      }
      return this.watermarkVisibleFrame()
    },
    watermarkPinchPreviewFrame() {
      const gesture = this.watermarkPinchGesture
      if (!gesture || !gesture.startFrame) {
        return null
      }
      if (!gesture.commitFrame) {
        return gesture.startFrame
      }
      return {
        left: gesture.commitFrame.left,
        top: gesture.commitFrame.top,
        width: gesture.startFrame.width,
        height: gesture.startFrame.height,
        scale: gesture.commitFrame.scale,
        rotation: gesture.commitFrame.rotation
      }
    },
    watermarkPinchScaleRatio() {
      if (this.watermarkPinchGesture && this.watermarkPinchGesture.commitFrame) {
        return 1
      }
      if (this.watermarkPinchGesture && typeof this.watermarkPinchGesture.previewScaleRatio === 'number') {
        return this.watermarkPinchGesture.previewScaleRatio
      }
      return 1
    },
    watermarkFrameFromMovePosition(moveX, moveY, frame) {
      const baseFrame = frame || this.watermarkFrame
      const metrics = this.watermarkBoxMetrics(baseFrame.width, baseFrame.height, baseFrame.scale, baseFrame.rotation)
      const layerBounds = this.watermarkLayerBounds()
      const nextCenterX = layerBounds.left + moveX + metrics.containerWidth / 2
      const nextCenterY = layerBounds.top + moveY + metrics.containerHeight / 2
      return {
        left: nextCenterX - metrics.contentWidth / 2,
        top: nextCenterY - metrics.contentHeight / 2
      }
    },
    touchPoint(event) {
      const touch = this.pickTouchSource(event)
      return {
        x: this.pickTouchNumber(touch, event, ['pageX', 'clientX', 'screenX', 'x']),
        y: this.pickTouchNumber(touch, event, ['pageY', 'clientY', 'screenY', 'y'])
      }
    },
    pickTouchSource(event) {
      const groups = []
      if (event && event.touches) {
        groups.push(event.touches)
      }
      if (event && event.changedTouches) {
        groups.push(event.changedTouches)
      }
      if (event && event.detail && event.detail.touches) {
        groups.push(event.detail.touches)
      }
      if (event && event.detail && event.detail.changedTouches) {
        groups.push(event.detail.changedTouches)
      }
      for (let i = 0; i < groups.length; i += 1) {
        const group = groups[i]
        if (group && group.length > 0) {
          return group[0]
        }
      }
      return event && event.detail ? event.detail : (event || {})
    },
    pickTouchNumber(touch, event, names) {
      for (let i = 0; i < names.length; i += 1) {
        const name = names[i]
        const value = touch ? touch[name] : null
        if (typeof value === 'number') {
          return value
        }
        if (typeof value === 'string' && value.length > 0) {
          const numberValue = parseFloat(value)
          if (!isNaN(numberValue)) {
            return numberValue
          }
        }
      }
      const detail = event && event.detail ? event.detail : {}
      for (let i = 0; i < names.length; i += 1) {
        const name = names[i]
        const value = detail[name]
        if (typeof value === 'number') {
          return value
        }
        if (typeof value === 'string' && value.length > 0) {
          const numberValue = parseFloat(value)
          if (!isNaN(numberValue)) {
            return numberValue
          }
        }
      }
      return 0
    },
    cameraViewportBounds() {
      return resolveCameraViewportBounds(this.screenWidth, this.previewHeight)
    },
    watermarkEditBounds() {
      return this.cameraViewportBounds()
    },
    watermarkLayerBounds() {
      const editBounds = this.watermarkEditBounds()
      return {
        left: editBounds.left - WATERMARK_HANDLE_PAD,
        top: editBounds.top - WATERMARK_HANDLE_PAD,
        right: editBounds.right + WATERMARK_HANDLE_PAD,
        bottom: editBounds.bottom + WATERMARK_HANDLE_PAD
      }
    },
    watermarkContentSize(width, height, scale) {
      return {
        width: Math.max(1, width * scale),
        height: Math.max(1, height * scale)
      }
    },
    watermarkTemplateMinimumFrameSize(template) {
      const padding = Math.max(0, template.boxPadding || 0)
      const imageWidth = template.imagePath ? Math.max(0, template.imageWidth || 0) : 0
      const imageHeight = template.imagePath ? Math.max(0, template.imageHeight || 0) : 0
      const textWidth = template.mainTitleText || template.subtitleText ? 1 : 0
      const imageTextGap = imageWidth > 0 && textWidth > 0 ? Math.max(0, template.imageTextGap || 0) : 0
      return {
        width: imageWidth + imageTextGap + textWidth + padding * 2,
        height: imageHeight + padding * 2
      }
    },
    watermarkTemplateFrameSize(template, viewport) {
      const minimumFrameSize = this.watermarkTemplateMinimumFrameSize(template)
      return {
        width: Math.max(
          WATERMARK_DEFAULT_MIN_WIDTH,
          minimumFrameSize.width,
          Math.round(viewport.width * (template.boxWidth || 0.58))
        ),
        height: Math.max(
          WATERMARK_DEFAULT_MIN_HEIGHT,
          minimumFrameSize.height,
          Math.round(viewport.height * (template.boxHeight || 0.14))
        )
      }
    },
    watermarkBoxMetrics(width, height, scale, rotation) {
      const contentSize = this.watermarkContentSize(width, height, scale)
      const boxWidth = contentSize.width + WATERMARK_HANDLE_PAD * 2
      const boxHeight = contentSize.height + WATERMARK_HANDLE_PAD * 2
      const bounds = this.watermarkRotatedBounds(boxWidth, boxHeight, rotation)
      const containerWidth = Math.max(1, bounds.width, boxWidth)
      const containerHeight = Math.max(1, bounds.height, boxHeight)
      return {
        contentWidth: contentSize.width,
        contentHeight: contentSize.height,
        boxWidth,
        boxHeight,
        containerWidth,
        containerHeight,
        transformLeft: (containerWidth - boxWidth) / 2,
        transformTop: (containerHeight - boxHeight) / 2
      }
    },
    watermarkRotatedBounds(width, height, rotation) {
      const radians = rotation * Math.PI / 180
      const cos = Math.abs(Math.cos(radians))
      const sin = Math.abs(Math.sin(radians))
      return {
        width: width * cos + height * sin,
        height: width * sin + height * cos
      }
    },
    clampCenterBySize(center, minEdge, maxEdge, size) {
      if (maxEdge <= minEdge || size >= maxEdge - minEdge) {
        return (minEdge + maxEdge) / 2
      }
      return this.clampNumber(center, minEdge + size / 2, maxEdge - size / 2)
    },
    limitWatermarkPinchScale(rawScale, previousScale, minScale, maxScale) {
      const targetScale = this.clampNumber(rawScale, minScale, maxScale)
      if (typeof previousScale !== 'number') {
        return targetScale
      }
      const delta = targetScale - previousScale
      if (Math.abs(delta) <= WATERMARK_PINCH_MAX_SCALE_STEP) {
        return targetScale
      }
      const smoothedDelta = delta * WATERMARK_PINCH_SMOOTHING
      const limitedDelta = this.clampNumber(smoothedDelta, -WATERMARK_PINCH_MAX_SCALE_STEP, WATERMARK_PINCH_MAX_SCALE_STEP)
      return this.clampNumber(previousScale + limitedDelta, minScale, maxScale)
    },
    clampWatermarkFrame(left, top, scale, rotation, width, height) {
      const frameWidth = typeof width === 'number' ? width : this.watermarkFrame.width
      const frameHeight = typeof height === 'number' ? height : this.watermarkFrame.height
      const nextRotation = normalizeRotation(rotation)
      const maxScale = this.maxWatermarkScale(left, top, nextRotation, frameWidth, frameHeight)
      const nextScale = this.clampNumber(scale, Math.min(WATERMARK_MIN_SCALE, maxScale), maxScale)
      const size = this.watermarkContentSize(frameWidth, frameHeight, nextScale)
      const metrics = this.watermarkBoxMetrics(frameWidth, frameHeight, nextScale, nextRotation)
      const editBounds = this.watermarkEditBounds()
      const layerBounds = this.watermarkLayerBounds()
      const centerX = left + size.width / 2
      const centerY = top + size.height / 2
      const clampedCenterX = this.clampCenterBySize(centerX, layerBounds.left, layerBounds.right, metrics.containerWidth)
      const clampedCenterY = this.clampCenterBySize(centerY, layerBounds.top, layerBounds.bottom, metrics.containerHeight)
      const contentLeft = this.clampNumber(clampedCenterX - size.width / 2, editBounds.left, editBounds.right - size.width)
      const contentTop = this.clampNumber(clampedCenterY - size.height / 2, editBounds.top, editBounds.bottom - size.height)
      return {
        left: contentLeft,
        top: contentTop,
        scale: nextScale,
        rotation: nextRotation
      }
    },
    watermarkCenter() {
      const size = this.watermarkContentSize(this.watermarkFrame.width, this.watermarkFrame.height, this.watermarkFrame.scale)
      return {
        x: this.watermarkFrame.left + size.width / 2,
        y: this.watermarkFrame.top + size.height / 2
      }
    },
    watermarkMovePositionFromFrame(frame) {
      const sourceFrame = frame || this.watermarkFrame
      const metrics = this.watermarkBoxMetrics(sourceFrame.width, sourceFrame.height, sourceFrame.scale, sourceFrame.rotation)
      const layerBounds = this.watermarkLayerBounds()
      const size = this.watermarkContentSize(sourceFrame.width, sourceFrame.height, sourceFrame.scale)
      const center = {
        x: sourceFrame.left + size.width / 2,
        y: sourceFrame.top + size.height / 2
      }
      return {
        x: roundWatermarkPx(center.x - metrics.containerWidth / 2 - layerBounds.left),
        y: roundWatermarkPx(center.y - metrics.containerHeight / 2 - layerBounds.top)
      }
    },
    maxWatermarkScale(left, top, rotation, width, height) {
      const frameWidth = Math.max(1, typeof width === 'number' ? width : this.watermarkFrame.width)
      const frameHeight = Math.max(1, typeof height === 'number' ? height : this.watermarkFrame.height)
      const targetRotation = typeof rotation === 'number' ? rotation : this.watermarkFrame.rotation
      const radians = targetRotation * Math.PI / 180
      const cos = Math.abs(Math.cos(radians))
      const sin = Math.abs(Math.sin(radians))
      const editBounds = this.watermarkEditBounds()
      const layerBounds = this.watermarkLayerBounds()
      const availableWidth = Math.max(1, layerBounds.right - layerBounds.left)
      const availableHeight = Math.max(1, layerBounds.bottom - layerBounds.top)
      const rotatedWidthFactor = Math.max(1, frameWidth * cos + frameHeight * sin)
      const rotatedHeightFactor = Math.max(1, frameWidth * sin + frameHeight * cos)
      const handlePadding = WATERMARK_HANDLE_PAD * 2
      const rotatedHandlePadding = handlePadding * (cos + sin)
      const maxWidthScale = (availableWidth - rotatedHandlePadding) / rotatedWidthFactor
      const maxHeightScale = (availableHeight - rotatedHandlePadding) / rotatedHeightFactor
      const contentMaxWidthScale = Math.max(1, editBounds.right - editBounds.left) / frameWidth
      const contentMaxHeightScale = Math.max(1, editBounds.bottom - editBounds.top) / frameHeight
      return Math.max(WATERMARK_ABSOLUTE_MIN_SCALE, Math.min(WATERMARK_MAX_SCALE, maxWidthScale, maxHeightScale, contentMaxWidthScale, contentMaxHeightScale))
    },
    clampNumber(value, min, max) {
      if (max < min) {
        return min
      }
      return Math.min(max, Math.max(min, value))
    },
    watermarkTemplateCardClass(template) {
      const classes = ['watermarkTemplateCard']
      if (this.activeWatermark && this.activeWatermark.templateId === template.templateId) {
        classes.push('watermarkTemplateCardActive')
      }
      return classes
    },
    templateTypeLabel(type) {
      if (type === 'image') {
        return '图片'
      }
      if (type === 'mixed') {
        return '图文'
      }
      return '文字'
    },
    goBack() {
      if (this.isRecording || this.stopPending || this.recordStartPending) {
        this.nativeStatus = this.stopPending ? '请等待视频保存完成' : (this.recordStartPending ? '录像启动中' : '请先停止录像')
        return
      }
      uni.navigateBack()
    },
    setMode(mode) {
      if (this.isRecording || this.stopPending || this.recordStartPending) {
        this.nativeStatus = this.stopPending ? '请等待视频保存完成' : (this.recordStartPending ? '录像启动中不能切换模式' : '录像中不能切换模式')
        return
      }
      if (mode === this.mode) {
        return
      }
      this.triggerHaptic('light')
      this.recordStartAfterPermission = false
      this.clearRecordPermissionRetry()
      this.clearRecordStartRetry()
      this.mode = mode
    },
    async toggleCameraSound() {
      if (this.cameraSoundPending) {
        return
      }
      this.cameraSoundPending = true
      this.triggerHaptic('light')
      const nextEnabled = !this.cameraSoundEnabled
      this.cameraSoundEnabled = nextEnabled
      const nativeCamera = this.resolveNativeCamera()
      try {
        if (nativeCamera && typeof nativeCamera.setCameraSoundEnabled === 'function') {
          const nativeResponse = await nativeCamera.setCameraSoundEnabled(nextEnabled)
          if (!this.nativeReturnIsEmpty(nativeResponse)) {
            const result = this.normalizeNativeResult(nativeResponse, '提示音设置失败')
            if (!result.success) {
              this.cameraSoundEnabled = !nextEnabled
              this.nativeStatus = result.errorMessage || '提示音设置失败'
              return
            }
            if (result.data && typeof result.data.cameraSoundEnabled === 'boolean') {
              this.cameraSoundEnabled = result.data.cameraSoundEnabled
            }
          }
        }
        const statusMessage = this.cameraSoundEnabled ? '提示音已开启' : '提示音已关闭'
        this.nativeStatus = statusMessage
        this.showCameraSoundToast(statusMessage)
      } catch (error) {
        this.cameraSoundEnabled = !nextEnabled
        this.nativeStatus = error && error.message ? error.message : '提示音设置失败'
      } finally {
        this.cameraSoundPending = false
      }
    },
    showCameraSoundToast(message) {
      try {
        if (typeof uni !== 'undefined' && typeof uni.showToast === 'function') {
          uni.showToast({
            title: message,
            icon: 'none',
            duration: 900
          })
        }
      } catch (error) {
      }
    },
    async cycleFlashMode() {
      if (this.flashPending) {
        return
      }
      const tappedAt = Date.now()
      if (tappedAt - this.flashTapAt < 280) {
        return
      }
      this.flashTapAt = tappedAt
      if (this.isRecording || this.stopPending) {
        this.nativeStatus = this.stopPending ? '请等待视频保存完成' : '录像中不能切换闪光灯'
        return
      }
      const currentFlashMode = this.flashMode
      const nextMode = this.nextFlashMode(currentFlashMode)
      this.flashPending = true
      this.nativeStatus = '闪光灯切换中'
      this.flashMode = nextMode
      try {
        const applied = await this.syncFlashMode(nextMode, false)
        if (!applied) {
          this.flashMode = currentFlashMode
        }
      } finally {
        this.flashPending = false
      }
    },
    async syncFlashMode(mode, silent) {
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.setFlashMode !== 'function') {
        this.nativeStatus = '原生闪光灯接口不可用'
        return false
      }
      try {
        this.flashEventHandled = false
        this.flashEventApplied = true
        this.flashRequestSilent = silent === true
        const nativeResponse = await nativeCamera.setFlashMode(mode)
        if (typeof nativeResponse === 'number' || nativeResponse === null || nativeResponse === undefined) {
          const eventHandled = this.flashEventHandled === true
          const eventApplied = this.flashEventApplied === true
          this.flashRequestSilent = false
          if (eventHandled) {
            return eventApplied
          }
          if (silent !== true) {
            this.nativeStatus = this.flashModeLabel(mode)
          }
          return true
        }
        const result = this.normalizeNativeResult(nativeResponse, '闪光灯设置失败')
        this.flashRequestSilent = false
        if (!result.success) {
          this.nativeStatus = result.errorMessage || '闪光灯设置失败'
          return false
        }
        if (result.data && result.data.applied === false && mode !== 'off') {
          this.nativeStatus = result.data.message || '当前设备不支持该闪光灯模式'
          return false
        }
        if (silent !== true) {
          this.nativeStatus = result.data && result.data.message ? result.data.message : this.flashModeLabel(mode)
        }
        return true
      } catch (error) {
        this.flashRequestSilent = false
        this.nativeStatus = error && error.message ? error.message : '闪光灯设置失败'
        return false
      }
    },
    nextFlashMode(currentFlashMode) {
      return currentFlashMode === 'off' ? 'on' : (currentFlashMode === 'on' ? 'auto' : 'off')
    },
    flashModeLabel(mode) {
      if (mode === 'on') {
        return '闪光灯：开'
      }
      if (mode === 'auto') {
        return '闪光灯：自动'
      }
      return '闪光灯：关'
    },
    async setZoomMode(mode) {
      if (this.zoomPending || mode === this.zoomMode) {
        return
      }
      if (this.stopPending) {
        this.nativeStatus = '请等待视频保存完成'
        return
      }
      const currentZoomMode = this.zoomMode
      this.zoomPending = true
      this.nativeStatus = '焦段切换中'
      try {
        const applied = await this.syncZoomMode(mode, false)
        if (!applied) {
          this.zoomMode = currentZoomMode
        }
      } finally {
        this.zoomPending = false
      }
    },
    async syncZoomMode(mode, silent) {
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.setZoomMode !== 'function') {
        if (silent !== true) {
          this.nativeStatus = '原生焦段接口不可用'
        }
        return false
      }
      try {
        this.zoomEventHandled = false
        this.zoomEventApplied = true
        this.zoomRequestSilent = silent === true
        const nativeResponse = await nativeCamera.setZoomMode(mode)
        if (typeof nativeResponse === 'number' || nativeResponse === null || nativeResponse === undefined) {
          const eventHandled = this.zoomEventHandled === true
          const eventApplied = this.zoomEventApplied === true
          this.zoomRequestSilent = false
          if (eventHandled) {
            return eventApplied
          }
          if (silent !== true) {
            this.nativeStatus = this.zoomModeLabel(mode)
          }
          this.zoomMode = mode
          return true
        }
        const result = this.normalizeNativeResult(nativeResponse, '焦段切换失败')
        this.zoomRequestSilent = false
        if (!result.success) {
          if (silent !== true) {
            this.nativeStatus = result.errorMessage || '焦段切换失败'
          }
          return false
        }
        if (result.data && result.data.applied === false) {
          if (silent !== true) {
            this.nativeStatus = result.data.message || '当前设备不支持该焦段'
          }
          return false
        }
        this.zoomMode = result.data && result.data.zoomMode ? result.data.zoomMode : mode
        if (silent !== true) {
          this.nativeStatus = result.data && result.data.message ? result.data.message : this.zoomModeLabel(this.zoomMode)
        }
        return true
      } catch (error) {
        this.zoomRequestSilent = false
        if (silent !== true) {
          this.nativeStatus = error && error.message ? error.message : '焦段切换失败'
        }
        return false
      }
    },
    zoomModeLabel(mode) {
      if (mode === 'wide') {
        return '焦段：广角'
      }
      if (mode === '2x') {
        return '焦段：2x'
      }
      return '焦段：1x'
    },
    async switchCameraFacing() {
      if (this.cameraSwitchPending) {
        return
      }
      const tappedAt = Date.now()
      if (tappedAt - this.cameraSwitchTapAt < 280) {
        return
      }
      this.cameraSwitchTapAt = tappedAt
      if (this.isRecording || this.stopPending || this.recordStartPending) {
        this.nativeStatus = this.stopPending ? '请等待视频保存完成' : '录像中不能切换摄像头'
        return
      }
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.switchCamera !== 'function') {
        this.nativeStatus = '原生摄像头切换接口不可用'
        return
      }
      this.cameraSwitchPending = true
      this.nativeStatus = '摄像头切换中'
      try {
        const nativeResponse = await nativeCamera.switchCamera()
        const result = this.normalizeNativeResult(nativeResponse, '摄像头切换失败')
        if (!result.success) {
          this.nativeStatus = result.errorMessage || '摄像头切换失败'
          return
        }
        if (result.data && result.data.applied === false) {
          this.nativeStatus = result.data.message || '当前设备不支持切换摄像头'
          return
        }
        this.applyNativeCameraState(result.data)
        this.nativeStatus = result.data && result.data.message ? result.data.message : this.cameraFacingLabel(this.cameraFacing)
      } catch (error) {
        this.nativeStatus = error && error.message ? error.message : '摄像头切换失败'
      } finally {
        this.cameraSwitchPending = false
      }
    },
    cameraFacingLabel(facing) {
      return facing === 'front' ? '前置摄像头' : '后置摄像头'
    },
    async pressShutter() {
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera) {
        this.nativeStatus = '原生相机组件不可用'
        return
      }

      if (this.mode === 'photo') {
        if (typeof nativeCamera.takePhoto !== 'function') {
          this.nativeStatus = '拍照接口不可用'
          return
        }
        this.triggerHaptic('light')
        if (this.activeWatermark && !await this.flushWatermarkSync(true)) {
          return
        }
        const result = await this.normalizeNativeCommandReturn(await nativeCamera.takePhoto(), '拍照失败', '拍照中', ['10', '11', '13', '14'])
        if (result.success) {
          this.nativeStatus = result.data && result.data.message ? result.data.message : '拍照中'
        } else {
          this.nativeStatus = result.errorMessage || '拍照失败'
        }
        return
      }

      if (!this.isRecording) {
        if (this.recordStartPending) {
          return
        }
        if (this.stopPending) {
          return
        }
        if (typeof nativeCamera.startRecord !== 'function') {
          this.nativeStatus = '录像接口不可用'
          return
        }
        this.triggerHaptic('medium')
        if (!await this.prepareRecordPermissions()) {
          this.recordStartAfterPermission = true
          this.scheduleRecordPermissionRetry()
          return
        }
        this.recordStartAfterPermission = false
        this.clearRecordPermissionRetry()
        if (this.activeWatermark && !await this.flushWatermarkSync(true)) {
          return
        }
        this.recordStartPending = true
        this.startRecordPendingTimeout()
        const recordResponse = await nativeCamera.startRecord({ fps: this.targetFps })
        const result = await this.normalizeNativeCommandReturn(recordResponse, '录像开始失败', '录像启动中', ['10', '11', '14'])
        if (result.success) {
          if (!this.isRecording && !this.nativeReturnIsEmpty(recordResponse)) {
            this.startRecordingClock()
            this.isRecording = true
            this.clearRecordStartPendingTimer()
            this.recordStartPending = false
          }
          this.nativeStatus = this.nativeReturnIsEmpty(recordResponse) ? '录像启动中' : '录像中'
        } else {
          this.stopRecordingClock()
          this.clearRecordStartPendingTimer()
          this.recordStartPending = false
          this.nativeStatus = result.errorMessage || '录像开始失败'
        }
        return
      }

      if (typeof nativeCamera.stopRecord !== 'function') {
        this.nativeStatus = '停止录像接口不可用'
        return
      }
      this.triggerHaptic('medium')
      this.isRecording = false
      this.stopPending = true
      this.nativeStatus = '正在保存视频'
      this.stopRecordingClock()
      this.startRecordStopPendingTimeout()
      try {
        const stopResponse = await nativeCamera.stopRecord()
        const result = await this.normalizeNativeCommandReturn(stopResponse, '录像停止失败', '视频保存中', ['14'])
        if (!this.stopPending) {
          return
        }
        if (result.success) {
          this.nativeStatus = result.data && result.data.message ? result.data.message : '视频保存中'
          if (this.nativeStatus !== '视频保存中') {
            this.clearRecordStopPendingTimer()
            this.stopPending = false
          }
        } else {
          this.nativeStatus = result.errorMessage || '录像停止失败'
          this.clearRecordStopPendingTimer()
          this.stopPending = false
        }
      } catch (error) {
        this.nativeStatus = error && error.message ? error.message : '录像停止失败'
        this.clearRecordStopPendingTimer()
        this.stopPending = false
      }
    },
    formatRecordElapsed(elapsedMs) {
      const totalSeconds = Math.max(0, Math.floor(elapsedMs / 1000))
      const minutes = Math.floor(totalSeconds / 60)
      const seconds = totalSeconds % 60
      const minuteText = minutes < 10 ? '0' + minutes : '' + minutes
      const secondText = seconds < 10 ? '0' + seconds : '' + seconds
      return minuteText + ':' + secondText
    },
    startRecordingClock() {
      this.stopRecordingClock()
      this.recordStartedAt = Date.now()
      this.recordElapsedMs = 0
      this.recordBlinkOn = true
      this.recordTimer = setInterval(() => {
        this.recordElapsedMs = Date.now() - this.recordStartedAt
        this.recordBlinkOn = !this.recordBlinkOn
      }, 500)
    },
    stopRecordingClock() {
      if (this.recordTimer !== null) {
        clearInterval(this.recordTimer)
        this.recordTimer = null
      }
      this.recordStartedAt = 0
      this.recordElapsedMs = 0
      this.recordBlinkOn = true
    },
    clearRecordPermissionRetry() {
      if (this.recordPermissionRetryTimer !== null) {
        clearTimeout(this.recordPermissionRetryTimer)
        this.recordPermissionRetryTimer = null
      }
      this.recordPermissionRetryCount = 0
    },
    clearRecordStartRetry() {
      if (this.recordStartRetryTimer !== null) {
        clearTimeout(this.recordStartRetryTimer)
        this.recordStartRetryTimer = null
      }
    },
    clearRecordStartPendingTimer() {
      if (this.recordStartPendingTimer !== null) {
        clearTimeout(this.recordStartPendingTimer)
        this.recordStartPendingTimer = null
      }
    },
    clearRecordStopPendingTimer() {
      if (this.recordStopPendingTimer !== null) {
        clearTimeout(this.recordStopPendingTimer)
        this.recordStopPendingTimer = null
      }
    },
    startRecordPendingTimeout() {
      this.clearRecordStartPendingTimer()
      this.recordStartPendingTimer = setTimeout(() => {
        this.recordStartPendingTimer = null
        if (this.recordStartPending && !this.isRecording) {
          this.recordStartPending = false
          this.stopRecordingClock()
          this.nativeStatus = '录像启动超时，请重试'
        }
      }, 3200)
    },
    startRecordStopPendingTimeout() {
      this.clearRecordStopPendingTimer()
      this.recordStopPendingTimer = setTimeout(() => {
        this.recordStopPendingTimer = null
        if (this.stopPending) {
          this.stopPending = false
          this.nativeStatus = '视频保存超时，请重试'
        }
      }, RECORD_STOP_TIMEOUT_MS)
    },
    scheduleRecordPermissionRetry() {
      if (!this.recordStartAfterPermission || this.recordPermissionRetryTimer !== null) {
        return
      }
      const nativeCamera = this.resolveNativeCamera()
      if (!nativeCamera || typeof nativeCamera.prepareRecordPermissions !== 'function') {
        return
      }
      this.recordPermissionRetryTimer = setTimeout(async () => {
        this.recordPermissionRetryTimer = null
        if (!this.recordStartAfterPermission || this.isRecording || this.stopPending || this.mode !== 'video') {
          this.clearRecordPermissionRetry()
          this.recordStartAfterPermission = false
          return
        }
        this.recordPermissionRetryCount += 1
        const ready = await this.prepareRecordPermissions(true)
        if (ready) {
          this.clearRecordPermissionRetry()
          this.recordStartAfterPermission = false
          this.retryCameraAfterPermission()
          this.nativeStatus = '录像权限已准备，正在开始录像'
          this.clearRecordStartRetry()
          this.recordStartRetryTimer = setTimeout(() => {
            this.recordStartRetryTimer = null
            if (!this.isRecording && !this.stopPending && this.recordStartAfterPermission === false && this.mode === 'video') {
              this.pressShutter()
            }
          }, 180)
          return
        }
        if (this.recordPermissionRetryCount < 80) {
          this.scheduleRecordPermissionRetry()
          return
        }
        this.clearRecordPermissionRetry()
        this.recordStartAfterPermission = false
        this.nativeStatus = '请先完成录像权限授权'
      }, 350)
    },
    prepareCameraPermissions() {
      const nativeCamera = this.resolveNativeCamera()
      if (nativeCamera && typeof nativeCamera.preparePermissions === 'function') {
        const result = this.normalizeNativeResult(nativeCamera.preparePermissions(), '权限准备失败')
        if (result.success && result.data && result.data.message) {
          this.nativeStatus = result.data.message
        }
        return result.success === true
      }
      return false
    },
    async prepareRecordPermissions(silent) {
      const nativeCamera = this.resolveNativeCamera()
      if (nativeCamera && typeof nativeCamera.prepareRecordPermissions === 'function') {
        const result = await this.normalizeNativeCommandReturn(nativeCamera.prepareRecordPermissions(), '请先完成录像权限授权', '录像权限已准备', ['10'])
        if (result.success === true) {
          this.clearRecordPermissionRetry()
          if (result.data && result.data.message && silent !== true) {
            this.nativeStatus = result.data.message
          }
          return true
        }
        if (silent !== true) {
          this.nativeStatus = result.errorMessage || '请先完成录像权限授权'
        }
        return false
      }
      return this.prepareCameraPermissions()
    },
    retryCameraAfterPermission() {
      if (this.isRecording || this.stopPending) {
        return
      }
      const nativeCamera = this.resolveNativeCamera()
      if (nativeCamera && typeof nativeCamera.restartCamera === 'function') {
        const result = this.normalizeNativeResult(nativeCamera.restartCamera(), '相机重试失败')
        if (result.success) {
          this.nativeStatus = '相机已准备'
        }
      }
    }
  }
}

function resolveScreenBounds() {
  try {
    const info = uni.getSystemInfoSync()
    return normalizePortraitLayoutBounds(
      info.windowWidth || PORTRAIT_LAYOUT_FALLBACK_WIDTH,
      info.windowHeight || PORTRAIT_LAYOUT_FALLBACK_HEIGHT
    )
  } catch (_) {
    return {
      width: PORTRAIT_LAYOUT_FALLBACK_WIDTH,
      height: PORTRAIT_LAYOUT_FALLBACK_HEIGHT
    }
  }
}

function normalizePortraitLayoutBounds(width, height) {
  const safeWidth = Math.max(1, Number(width) || PORTRAIT_LAYOUT_FALLBACK_WIDTH)
  const safeHeight = Math.max(1, Number(height) || PORTRAIT_LAYOUT_FALLBACK_HEIGHT)
  return {
    width: Math.min(safeWidth, safeHeight),
    height: Math.max(safeWidth, safeHeight)
  }
}

function resolveCameraViewportBounds(width, height) {
  const safeWidth = Math.max(1, Number(width) || PORTRAIT_LAYOUT_FALLBACK_WIDTH)
  const safeHeight = Math.max(1, Number(height) || PORTRAIT_LAYOUT_FALLBACK_HEIGHT)
  const availableTop = CAMERA_TOP_BAR_HEIGHT
  const availableBottom = Math.max(availableTop + 1, safeHeight - CAMERA_BOTTOM_PANEL_HEIGHT)
  const availableHeight = Math.max(1, availableBottom - availableTop)
  const targetWidth = Math.min(
    safeWidth,
    availableHeight * CAMERA_VIEWPORT_ASPECT_WIDTH / CAMERA_VIEWPORT_ASPECT_HEIGHT
  )
  const targetHeight = targetWidth * CAMERA_VIEWPORT_ASPECT_HEIGHT / CAMERA_VIEWPORT_ASPECT_WIDTH
  const left = (safeWidth - targetWidth) / 2
  const top = availableTop + (availableHeight - targetHeight) / 2
  return {
    left,
    top,
    right: left + targetWidth,
    bottom: top + targetHeight,
    width: targetWidth,
    height: targetHeight
  }
}

function createWatermarkTemplates() {
  const logo = '/static/watermark/logo3.png'
  return [
    {
      templateId: 'text-delivery',
      templateName: '纯文字',
      templateType: 'text',
      mainTitleText: '今日水印',
      subtitleText: 'Android 首版',
      mainTitleColor: '#f7f7f7',
      subtitleColor: 'rgba(255,255,255,0.82)',
      mainTitleFontSize: 18,
      subtitleFontSize: 12,
      mainTitleBold: true,
      subtitleBold: false,
      imagePath: '',
      imageWidth: 0,
      imageHeight: 0,
      imageTextGap: 0,
      boxWidth: 0.58,
      boxHeight: 0.14,
      boxBackgroundColor: 'rgba(22,24,26,0.58)',
      boxRadius: 10,
      boxPadding: 12,
      opacity: 0.94,
      positionX: 0.14,
      positionY: 0.16,
      scale: 1,
      rotation: 0
    },
    {
      templateId: 'image-logo',
      templateName: '纯图片',
      templateType: 'image',
      mainTitleText: '',
      subtitleText: '',
      mainTitleColor: '#ffffff',
      subtitleColor: '#ffffff',
      mainTitleFontSize: 0,
      subtitleFontSize: 0,
      mainTitleBold: false,
      subtitleBold: false,
      imagePath: logo,
      imageWidth: 72,
      imageHeight: 72,
      imageTextGap: 0,
      boxWidth: 0.34,
      boxHeight: 0.18,
      boxBackgroundColor: 'rgba(255,255,255,0.8)',
      boxRadius: 14,
      boxPadding: 12,
      opacity: 0.94,
      positionX: 0.16,
      positionY: 0.16,
      scale: 1,
      rotation: 0
    },
    {
      templateId: 'mixed-site',
      templateName: '图文',
      templateType: 'mixed',
      mainTitleText: '南京西路',
      subtitleText: '门店巡检 · 2026-06-22',
      mainTitleColor: '#f7f7f7',
      subtitleColor: 'rgba(255,255,255,0.82)',
      mainTitleFontSize: 18,
      subtitleFontSize: 12,
      mainTitleBold: true,
      subtitleBold: false,
      imagePath: logo,
      imageWidth: 36,
      imageHeight: 36,
      imageTextGap: 8,
      boxWidth: 0.66,
      boxHeight: 0.16,
      boxBackgroundColor: 'rgba(16,18,20,0.64)',
      boxRadius: 12,
      boxPadding: 12,
      opacity: 0.96,
      positionX: 0.12,
      positionY: 0.16,
      scale: 1,
      rotation: 0
    }
  ]
}

function cloneTemplate(template) {
  return JSON.parse(JSON.stringify(template))
}

function normalizeRotation(rotation) {
  if (rotation > 180) {
    return rotation - 360
  }
  if (rotation < -180) {
    return rotation + 360
  }
  return rotation
}

function roundWatermarkPx(value) {
  return Math.round(value * 1000) / 1000
}
</script>

<style>
.page {
  flex: 1;
  background-color: #101614;
}

.nativePreview {
  position: absolute;
  background-color: #0b100e;
}

.watermarkLayer {
  position: absolute;
  z-index: 4;
}

.watermarkGesturePlane {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
}

.watermarkPinchVisualLayer {
  position: absolute;
  z-index: 3;
}

.watermarkTransformBox {
  position: absolute;
}

.watermarkContent {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  border-width: 1px;
  border-style: solid;
  border-color: rgba(255, 255, 255, 0.86);
  z-index: 1;
}

.watermarkImage {
  width: 48px;
  height: 48px;
}

.watermarkTextBlock {
  flex: 1;
}

